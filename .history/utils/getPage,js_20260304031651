export const getPage = async(uri) => {
	const params = {
		query: gql`
      query PageQuery($uri: String!) {
        nodeByUri(uri: $uri) {
          ... on Page {
            id
            title
            blocks(postTemplate: false)
            seo {
              title
              metaDesc
            }
          }

          ... on Property {
            id
            title
            blocks(postTemplate: false)
          }
        }
        acfOptionsMainMenu {
          mainMenu {
            callToActionButton {
              label
              destination {
                ... on Page {
                  uri
                }
              }
            }
            menuItems {
              menuItem {
                label
                destination {
                  ... on Page {
                    uri
                  }
                }
              }
              items {
                label
                destination {
                  ... on Page {
                    uri
                  }
                }
              }
            }
          }
        }
      }
    `,
	}
}